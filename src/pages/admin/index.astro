---
// Decap CMS admin shell — explicit route so [...slug].astro does not shadow /admin
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Kujera Content</title>
    <!-- Relative config.yml resolves to /admin/config.yml (not site root) -->
    <base href="/admin/" />
    <script is:inline>
      if (window.location.pathname === '/admin') {
        window.location.replace('/admin/' + window.location.search + window.location.hash);
      }
    </script>
  </head>
  <body>
    <script is:inline src="https://unpkg.com/decap-cms@^3.8.0/dist/decap-cms.js"></script>
  </body>
</html>
