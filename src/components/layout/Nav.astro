---
import { localizeHref } from '../../lib/i18n';
import type { SiteSettings } from '../../types/site';

interface Props {
  settings: SiteSettings;
  currentPath: string;
  /** Transparent over hero on home/about; solid elsewhere. Scroll adds solid state on hero pages. */
  transparent?: boolean;
}

const { settings, transparent = false } = Astro.props;
---

<header
  class:list={['site-header', { 'site-header--transparent': transparent }]}
  data-site-header
  data-header-transparent={transparent ? 'true' : 'false'}
>
  <div class="site-header__shell">
    <div class="site-header__inner">
      <a href={localizeHref('/')} class="site-header__brand">
        {settings.logo ? (
          <img src={settings.logo} alt={settings.brandName} height="32" />
        ) : (
          settings.brandName
        )}
      </a>

      <nav class="site-header__nav site-header__nav--desktop" aria-label="Main">
        {settings.navLinks.map((link) => (
          <a href={localizeHref(link.href)}>{link.label}</a>
        ))}
      </nav>

      <div class="site-header__actions">
        <button
          type="button"
          class="site-header__menu-toggle"
          data-mobile-menu-toggle
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <span class="site-header__menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>

        <button
          type="button"
          class="cart-trigger site-header__bag"
          data-cart-open
          aria-label="Cart"
        >
          <svg class="site-header__bag-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 7h12l-1.2 11H7.2L6 7Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
            <path d="M9 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="cart-badge cart-badge--header" data-cart-count hidden>0</span>
        </button>
      </div>
    </div>
  </div>
</header>

<div
  class="mobile-menu"
  id="mobile-menu"
  data-mobile-menu
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
>
  <div class="mobile-menu__backdrop" data-mobile-menu-close aria-hidden="true"></div>
  <div class="mobile-menu__panel">
    <div class="mobile-menu__top">
      <a href={localizeHref('/')} class="mobile-menu__brand">{settings.brandName}</a>
      <button type="button" class="mobile-menu__close" data-mobile-menu-close aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <nav class="mobile-menu__nav" aria-label="Mobile">
      {settings.navLinks.map((link, index) => (
        <a
          href={localizeHref(link.href)}
          class="mobile-menu__link"
          style={`--i: ${index}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <p class="mobile-menu__tagline">{settings.tagline}</p>
  </div>
</div>

<script src="../../scripts/nav.client.ts"></script>

<style>
  .cart-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.35rem;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    background: var(--color-brand);
    color: var(--color-text-on-brand);
    border-radius: var(--radius-full);
  }

  .cart-badge--header {
    position: absolute;
    top: -0.25rem;
    inset-inline-end: -0.25rem;
    min-width: 1.125rem;
    height: 1.125rem;
    font-size: 0.625rem;
  }

  .cart-badge[hidden] {
    display: none;
  }

  .site-header__bag {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.125rem;
    height: 2.125rem;
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .site-header__bag-icon {
    width: 1.375rem;
    height: 1.375rem;
  }
</style>
