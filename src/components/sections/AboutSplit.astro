---
import Button from '../ui/Button.astro';
import { localizeHref } from '../../lib/i18n';
import type { AboutSplitSection } from '../../types/sections';
interface Props {
  section: AboutSplitSection;
}

const { section } = Astro.props;
const reverse = section.layout === 'image-right';
---

<section class:list={['about-split', { 'about-split--reverse': reverse }]}>
  <div class="about-split__media">
    <img
      class="about-split__img"
      src={section.image}
      alt=""
      loading="lazy"
      width="1800"
      height="1200"
    />
  </div>

  <div class="about-split__content">
    <div class="about-split__inner">
      {section.eyebrow && <p class="about-split__eyebrow">{section.eyebrow}</p>}
      <h2 class="about-split__headline">{section.headline}</h2>
      <p class="about-split__description">{section.description}</p>
      {section.cta && (
        <Button href={localizeHref(section.cta.href)} variant={section.cta.variant ?? 'secondary'}>
          {section.cta.label}
        </Button>
      )}
    </div>
  </div>
</section>
