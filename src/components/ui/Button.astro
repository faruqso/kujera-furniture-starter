---
import type { ButtonVariant, ButtonSize } from '../../types/sections';

interface Props {
  href?: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
  class?: string;
  type?: 'button' | 'submit';
  disabled?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
  disabled = false,
  ...rest
} = Astro.props;

const classes = `btn btn--${variant} btn--${size} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} {...rest}>
    <slot />
  </button>
)}
