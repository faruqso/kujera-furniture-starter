---
interface Props {
  action: string;
  placeholder?: string;
  name?: string;
  ariaLabel?: string;
  class?: string;
}

const {
  action,
  placeholder = 'Search',
  name = 'q',
  ariaLabel,
  class: className = '',
} = Astro.props;
---

<form class:list={['search-bar', className]} role="search" action={action}>
  <input
    type="search"
    name={name}
    class="search-bar__input"
    placeholder={placeholder}
    aria-label={ariaLabel ?? placeholder}
  />
  <button type="submit" class="search-bar__submit" aria-label="Search">
    <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" />
      <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  </button>
</form>
