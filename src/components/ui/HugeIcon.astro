---
import type { HugeIconData } from '../../lib/hugeicons';

interface Props {
  icon: HugeIconData;
  size?: number;
  class?: string;
}

const { icon, size = 24, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  class:list={['huge-icon', className]}
  aria-hidden="true"
>
  {
    icon.map(([tag, attrs]) => {
      const { key: _key, ...rest } = attrs;
      if (tag === 'path') {
        return <path {...rest} />;
      }
      if (tag === 'circle') {
        return <circle {...rest} />;
      }
      if (tag === 'rect') {
        return <rect {...rest} />;
      }
      return null;
    })
  }
</svg>
